# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-random-cron-secret

# Pagamentos Mercado Pago
# Obtenha as chaves em: https://www.mercadopago.com.br/developers/panel/app
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...   # Chave pública (usada no frontend/SDK JS)
MP_ACCESS_TOKEN=APP_USR-...             # Access Token (segredo — apenas backend)
MP_WEBHOOK_SECRET=                      # Chave secreta do webhook (painel MP > Webhooks)

# Correios (opcional para primeiro teste de vitrine)
CORREIOS_API_USER=
CORREIOS_API_PASS=
CORREIOS_CONTRACT_NUMBER=
